{
    "name": "blt-safecloak",
    "version": "0.1.0",
    "description": "Privacy-focused peer-to-peer communication platform",
    "private": true,
    "scripts": {
        "dev": "wrangler dev",
        "deploy": "wrangler deploy",
        "format": "yapf -i -r src/ && prettier --write \"src/**/*.html\" \"public/**/*.{js,css}\"",
        "format:check": "yapf -d -r src/ && prettier --check \"src/**/*.html\" \"public/**/*.{js,css}\"",
        "typecheck": "mypy src/",
        "check": "npm run format:check && npm run typecheck",
        "setup": "npm install && python -m  pip install -r requirements-dev.txt",
        "clean": "find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true"
    },
    "keywords": [
        "privacy",
        "p2p",
        "cloudflare-workers",
        "webrtc"
    ],
    "license": "MIT",
    "devDependencies": {
        "prettier": "^3.2.5"
    },
    "engines": {
        "node": ">=18.0.0",
        "python": ">=3.11"
    }
}